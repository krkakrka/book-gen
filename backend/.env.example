DJANGO_SECRET_KEY=change-me-in-production

# Local dev defaults below. On a real deploy, point these at your managed
# Postgres instance instead (e.g. Railway's Postgres addon exposes its own
# PGDATABASE/PGUSER/PGPASSWORD/PGHOST/PGPORT — reference those here).
POSTGRES_DB=storyseed_dev
POSTGRES_USER=storyseed
POSTGRES_PASSWORD=storyseed
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Only used by config.settings.local (DEBUG=True) — the dev-user seed
# migration is a no-op under config.settings.production.
DJANGO_DEV_USER_EMAIL=parent@home.com
DJANGO_DEV_USER_PASSWORD=secret

# Required only when DJANGO_SETTINGS_MODULE=config.settings.production:
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com
# CORS_ALLOWED_ORIGINS=https://example.com
# CSRF_TRUSTED_ORIGINS=https://example.com
